{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/((?!assets|favicon.ico|manifest.json|robots.txt|logo192.png|logo512.png|nft-images|index.html).*)",
      "dest": "/index.html"
    }
  ]
}